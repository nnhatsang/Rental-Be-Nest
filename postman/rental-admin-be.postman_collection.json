                  "if (json?.data?.id) {",
                  "  pm.collectionVariables.set('rentalOrderId', json.data.id);",
                  "}",
                  "if (json?.data?.items?.[0]?.id) {",
                  "  pm.collectionVariables.set('rentalOrderItemId', json.data.items[0].id);",
                  "}"
                ]
              }
            }
          ],
